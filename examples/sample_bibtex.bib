@article{zhang2024mrnalnp,
  title     = {mRNA-Lipid Nanoparticle Delivery Systems for Cancer Immunotherapy: Recent Advances and Clinical Perspectives},
  author    = {Zhang, Wei and Li, Xiaoming and Chen, Yu and Wang, Jing and Liu, Peng},
  journal   = {Advanced Drug Delivery Reviews},
  year      = {2024},
  volume    = {195},
  pages     = {114723},
  doi       = {10.1016/j.addr.2024.114723},
  abstract  = {Messenger RNA (mRNA) therapeutics delivered via lipid nanoparticles (LNPs) have emerged as a powerful platform for cancer immunotherapy. This review summarizes recent advances in ionizable lipid design, targeting strategies for the tumor microenvironment, and combination approaches with immune checkpoint blockade. We discuss key challenges including off-target delivery, immunogenicity, and manufacturing scalability.},
  keywords  = {mRNA delivery; lipid nanoparticle; cancer immunotherapy; tumor microenvironment; ionizable lipid}
}

@article{chen2023crispr,
  title     = {CRISPR-Cas13-Mediated RNA Editing for Therapeutic Applications},
  author    = {Chen, Hongbo and Patel, Ravi and Kim, Seo-yeon and Yamamoto, Takashi},
  journal   = {Nature Biotechnology},
  year      = {2023},
  volume    = {41},
  pages     = {1023--1035},
  doi       = {10.1038/s41587-023-01892-w},
  abstract  = {The CRISPR-Cas13 system enables precise RNA editing without permanent changes to the genome, offering a reversible approach to gene therapy. We report the development of high-fidelity Cas13 variants with reduced off-target activity and demonstrate therapeutic RNA editing in mouse models of neurodegenerative disease.},
  keywords  = {CRISPR-Cas13; RNA editing; gene therapy; ADAR; neurodegenerative disease}
}

@article{patel2025mlbdd,
  title     = {Machine Learning-Guided Design of Brain-Penetrant Drug Delivery Systems},
  author    = {Patel, Arjun and Nguyen, Thi and Martinez, Carlos and Johnson, Sarah and Brown, David},
  journal   = {Nature Biomedical Engineering},
  year      = {2025},
  volume    = {9},
  pages     = {45--58},
  doi       = {10.1038/s41551-025-01345-x},
  abstract  = {Crossing the blood-brain barrier (BBB) remains a major challenge in CNS drug delivery. We present a machine learning framework that predicts BBB penetration of nanoparticle formulations using physiochemical descriptors and in vitro BBB model training data. Our model identified novel peptide-functionalized liposomes achieving 4-fold higher brain accumulation compared to controls.},
  keywords  = {blood-brain barrier; machine learning; drug delivery; nanoparticle; peptide-functionalized liposome}
}

@article{kim2023exosome,
  title     = {Engineered Extracellular Vesicles as Targeted Delivery Vehicles for Nucleic Acid Therapeutics},
  author    = {Kim, Ji-won and Zhang, Lei and Andersen, Martin and Sato, Hiroki and Lee, Min-ji},
  journal   = {ACS Nano},
  year      = {2023},
  volume    = {17},
  number    = {14},
  pages     = {13240--13258},
  doi       = {10.1021/acsnano.3c04567},
  abstract  = {Extracellular vesicles (EVs) offer natural biocompatibility and tropism for nucleic acid delivery. We engineered EVs displaying tissue-specific targeting ligands and loaded with siRNA or mRNA cargo. In vivo studies demonstrated efficient gene silencing in hepatic and tumor tissues with minimal systemic toxicity.},
  keywords  = {extracellular vesicles; exosomes; siRNA delivery; mRNA delivery; targeted therapy}
}

@article{wang2024mof,
  title     = {Metal-Organic Frameworks for Stimuli-Responsive Drug Release in the Tumor Microenvironment},
  author    = {Wang, Yifan and Park, Sang-min and Garcia, Elena and Wang, Lei and Thompson, Rachel},
  journal   = {Journal of the American Chemical Society},
  year      = {2024},
  volume    = {146},
  pages     = {8921--8935},
  doi       = {10.1021/jacs.4c01234},
  abstract  = {Metal-organic frameworks (MOFs) provide tunable porosity and stimuli-responsive degradation ideal for drug delivery. We synthesized pH-sensitive MOFs loaded with doxorubicin that selectively release cargo in the acidic tumor microenvironment. The system achieved 85% tumor growth inhibition in a triple-negative breast cancer model with reduced cardiotoxicity.},
  keywords  = {MOF; metal-organic framework; drug delivery; pH-responsive; tumor microenvironment; doxorubicin}
}

@article{liu2025polymeric,
  title     = {Polymeric Micelles for Co-Delivery of Chemotherapy and Immunomodulators: A Comprehensive Evaluation},
  author    = {Liu, Xiaodong and Johnson, Emma and Park, Jun-ho and Wang, Zhen},
  journal   = {Biomaterials},
  year      = {2025},
  volume    = {310},
  pages     = {122634},
  doi       = {10.1016/j.biomaterials.2025.122634},
  abstract  = {Co-delivery of chemotherapeutic agents and immunomodulators via polymeric micelles represents a promising strategy for combination cancer therapy. We systematically evaluated 12 amphiphilic block copolymer formulations for loading efficiency, release kinetics, and in vivo antitumor efficacy.},
  keywords  = {polymeric micelles; co-delivery; chemotherapy; immunotherapy; combination therapy}
}

@article{thompson2024singlecell,
  title     = {Single-Cell Multi-Omics Characterization of Nanoparticle-Protein Corona Interactions},
  author    = {Thompson, Emily and Wu, Jian and Davis, Michael and Brown, Sarah and Lee, Hyun-woo},
  journal   = {Nature Nanotechnology},
  year      = {2024},
  volume    = {19},
  pages     = {345--358},
  doi       = {10.1038/s41565-024-01621-9},
  abstract  = {The protein corona formed on nanoparticle surfaces critically determines their biological fate. Using single-cell multi-omics (scRNA-seq + proteomics), we mapped corona composition across 14 cell types and identified cell-type-specific corona fingerprints that predict nanoparticle uptake patterns.},
  keywords  = {protein corona; single-cell; multi-omics; nanoparticle; proteomics}
}

@article{yamamoto2023ionizable,
  title     = {Rational Design of Ionizable Lipids for Endosomal Escape: A Structure-Activity Relationship Study},
  author    = {Yamamoto, Kenji and Smith, Robert and Chen, Wei and Park, Min-soo and Garcia, Luis},
  journal   = {Angewandte Chemie International Edition},
  year      = {2023},
  volume    = {62},
  pages     = {e202301234},
  doi       = {10.1002/anie.202301234},
  abstract  = {Efficient endosomal escape remains the rate-limiting step for LNP-mediated nucleic acid delivery. We synthesized a library of 96 ionizable lipids with systematic variations in headgroup, linker, and tail chemistry. Structure-activity analysis identified key design principles for maximizing endosomal disruption while minimizing cytotoxicity.},
  keywords  = {ionizable lipid; endosomal escape; LNP; structure-activity relationship; lipid design}
}

@article{brown2024aibbb,
  title     = {Deep Learning Prediction of Blood-Brain Barrier Permeability for Nanoparticle Formulations},
  author    = {Brown, Alexander and Zhang, Yifei and Kim, Tae-hyun and Martinez, Elena},
  journal   = {ACS Central Science},
  year      = {2024},
  volume    = {10},
  pages     = {567--579},
  doi       = {10.1021/acscentsci.4c00123},
  abstract  = {We developed a graph neural network (GNN) model trained on 2,500+ experimental BBB permeability measurements for nanoparticle formulations. The model identifies key molecular features governing brain uptake and was validated on 50 novel formulations.},
  keywords  = {deep learning; blood-brain barrier; nanoparticle; graph neural network; permeability prediction}
}

@article{sato2025peptide,
  title     = {Cell-Penetrating Peptide-Functionalized Nanoparticles for Intracellular Protein Delivery},
  author    = {Sato, Yuki and Chen, Emily and Park, David and Wang, Ruoxi and Tanaka, Hiroshi},
  journal   = {ACS Nano},
  year      = {2025},
  volume    = {19},
  pages     = {4567--4582},
  doi       = {10.1021/acsnano.5c00789},
  abstract  = {Intracellular delivery of therapeutic proteins using cell-penetrating peptide (CPP)-functionalized nanoparticles showed enhanced endosomal escape and cytosolic delivery. The CPP-nanoparticle platform successfully delivered functional CRISPR-Cas9 ribonucleoprotein complexes in hard-to-transfect primary cells.},
  keywords  = {cell-penetrating peptide; intracellular delivery; protein delivery; CRISPR-Cas9; nanoparticle}
}
